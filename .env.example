# Copy to .env for local development if needed.
# Do not commit real API keys.
QT_DATABASE_PATH=data/quant_trading.db
QT_LOG_DIR=data/logs
QT_MARKET_PROVIDER=akshare
QT_INTRADAY_INTERVAL_SECONDS=180
# Quote/minute stale threshold in effective XSHG trading minutes (1-60).
QT_MARKET_STALE_TRADING_MINUTES=6
QT_TIMEZONE=Asia/Shanghai
QT_ENABLE_MARKET_FETCH=true

# HTTP API. LAN access only; never expose this default bind directly to Internet.
# Use a local secret; do not commit real values.
QT_API_HOST=0.0.0.0
QT_API_PORT=8000
QT_API_ACCESS_PASSWORD=
QT_API_TOKEN_SECRET=
QT_API_TOKEN_TTL_SECONDS=3600

# Optional ordinary startup run. Close-window readiness recovery is independent.
QT_SERVICE_RUN_ON_START_WHEN_SCHEDULER_ENABLED=true

MX_APIKEY=your_miaoxiang_api_key_here
